@model IEnumerable<AirplaneViewModel>

@{
    ViewData["Title"] = "Airplanes";
}
<partial name="_notification" />
<h2>@ViewData["Title"] List</h2>
<p>
    <a asp-action="Create" class="btn btn-success">Add New Airplane</a>
</p>

    <table class="table table-striped table-bordered align-middle text-white">
        <thead class="table-dark">
            <tr>
                <th>Model</th>
                <th>Capacity</th>
                <th>Airline</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var airplane in Model)
                {
                    <tr class="text-white">
                        <td>@airplane.Model</td>
                        <td>@airplane.SeatCapacity</td>
                        <td>@airplane.Airline?.Name</td>
                        <td>
                           
                            <a asp-action="Edit" asp-route-id="@airplane.Id" class="btn btn-sm btn-warning text-white me-1">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a> | 
                             <a asp-action="Delete" asp-route-id="@airplane.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a> 
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">No airplanes available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
