@model AirplaneViewModel

@{
	ViewData["Title"] = "Edit Airplane";
}
<div class="container">
	<h2 class="text-center mb-4 ">Edit Airplane</h2>

	<form asp-action="Edit" method="post">
		<input type="hidden" asp-for="Id" />
		@Html.AntiForgeryToken()
		<div class="mb-3">
			<label asp-for="Model" class="form-label"></label>
			<input asp-for="Model" class="form-control" />
			<span asp-validation-for="Model" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="SeatCapacity" class="control-label"></label>
			<input asp-for="SeatCapacity" class="form-control" />
			<span asp-validation-for="SeatCapacity" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="AirlineId" class="control-label"></label>
			<select asp-for="AirlineId" class="form-control" asp-items="@ViewBag.Airlines"></select>
			<span asp-validation-for="AirlineId" class="text-danger"></span>
		</div>
		<div asp-validation-summary="All" class="text-danger"></div>

		<button type="submit" class="btn btn-primary">Save</button>
		<a asp-action="Index" class="btn btn-secondary">Back to List</a>
	</form>
</div>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
