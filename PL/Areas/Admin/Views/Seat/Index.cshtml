@model IEnumerable<SeatViewModel>

@{
    ViewData["Title"] = "Seats";
}
<partial name="_notification" />
<h2>@ViewData["Title"] List</h2>
<p>
    <a asp-action="Create" class="btn btn-success">Add New Seat</a>
</p>

    <table class="table table-striped table-bordered align-middle text-white">
        <thead class="table-dark">
            <tr>
                <th>Airport Model</th>
                <th>Number</th>
                <th>Row</th>
                <th>Class</th>
                <th>Price</th>
                <th>Is Available</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var seat in Model)
                {
                    <tr class="text-white">
                        <td>@seat.Airplane?.Model</td>
                        <td>@seat.Number</td>
                        <td>@seat.Row</td>
                        <td>@seat.Class</td>
                        <td>@seat.Price</td>
                        <td>@seat.IsAvailable</td>
                        <td>
                           
                            <a asp-action="Edit" asp-route-id="@seat.Id" class="btn btn-sm btn-warning text-white me-1">
                                <i class="bi bi-pencil-square"></i> Edit
                        </a>  |
                        <a asp-action="Details" asp-route-id="@seat.Id" class="btn btn-info btn-sm">
                            <i class="bi bi-trash"></i> Details
                        </a>  | 
                             <a asp-action="Delete" asp-route-id="@seat.Id" class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a> 
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">No Seat available.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
