@model SeatViewModel

@{
	ViewData["Title"] = "Edit Seat";
}
<div class="container">
	<h2 class="text-center mb-4 ">Edit Airplane</h2>

	<form asp-action="Edit" method="post">
		<input type="hidden" asp-for="Id" />
		@Html.AntiForgeryToken()

		<div class="mb-3">
			<label asp-for="AirplaneId" class="form-label"></label>
			<select asp-for="AirplaneId" class="form-select" asp-items="@ViewBag.Airplanes">
				<option value="">-- Select Airline --</option>
			</select>
			<span asp-validation-for="AirplaneId" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Class" class="form-label"></label>
			<select asp-for="Class" class="form-select" asp-items="@ViewBag.SeatClasses">
				<option value="">-- Select Airline --</option>
			</select>
			<span asp-validation-for="Class" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Number" class="form-label"></label>
			<input asp-for="Number" type="number" class="form-control" placeholder="Enter seat capacity" />
			<span asp-validation-for="Number" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Row" class="form-label"></label>
			<input asp-for="Row" class="form-control" placeholder="Enter airplane model" />
			<span asp-validation-for="Row" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="Price" class="form-label"></label>
			<input asp-for="Price" class="form-control" placeholder="Enter airplane model" />
			<span asp-validation-for="Price" class="text-danger"></span>
		</div>

		<div class="mb-3">
			<label asp-for="IsAvailable" class="form-label"></label>
			<input asp-for="IsAvailable" type="checkbox" class="form-check-input" />
			<span asp-validation-for="IsAvailable" class="text-danger"></span>
		</div>

		
		<div asp-validation-summary="All" class="text-danger"></div>

		<button type="submit" class="btn btn-primary">Save</button> |
		<a asp-action="Index" class="btn btn-secondary">Back to List</a>
	</form>
</div>
@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
