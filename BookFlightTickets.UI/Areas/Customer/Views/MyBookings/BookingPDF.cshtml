@model Booking
@{
	Layout = null;
}

<style>
	body {
		font-family: Arial, Helvetica, sans-serif;
		font-size: 12px;
		color: #333;
	}

	.header {
		text-align: center;
		border-bottom: 2px solid #000;
		padding-bottom: 10px;
		margin-bottom: 20px;
	}

	.section {
		margin-bottom: 20px;
	}

	.box {
		border: 1px solid #000;
		padding: 10px;
		margin-bottom: 10px;
	}

	.title {
		font-weight: bold;
		margin-bottom: 5px;
		text-transform: uppercase;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 5px;
	}

	th, td {
		border: 1px solid #000;
		padding: 6px;
		text-align: left;
	}

	th {
		background: #eee;
	}

	.ticket {
		border: 2px dashed #000;
		padding: 10px;
		margin-bottom: 20px;
	}

	.right {
		text-align: right;
	}

	.center {
		text-align: center;
	}
</style>

<!-- HEADER -->
<div class="header">
	<h2>BOARDING PASS</h2>
	<div><strong>PNR:</strong> @Model.PNR</div>
	<div><strong>Status:</strong> @Model.Status</div>
</div>

<!-- BOOKING INFO -->
<div class="section box">
	<div class="title">Flight Information</div>
	<table>
		<tr>
			<th>Airline</th>
			<td>@Model.Flight.Airline.Name</td>
			<th>Aircraft</th>
			<td>@Model.Flight.Airplane.Model</td>
		</tr>
		<tr>
			<th>From</th>
			<td>@Model.Flight.DepartureAirport.Name</td>
			<th>To</th>
			<td>@Model.Flight.ArrivalAirport.Name</td>
		</tr>
		<tr>
			<th>Departure</th>
			<td>@Model.Flight.DepartureTime.ToString("dd MMM yyyy HH:mm")</td>
			<th>Arrival</th>
			<td>@Model.Flight.ArrivalTime.ToString("dd MMM yyyy HH:mm")</td>
		</tr>
	</table>
</div>

<!-- PAYMENT -->
@if (Model.Payment != null)
{
	<div class="section box">
		<div class="title">Payment Receipt</div>
		<table>
			<tr>
				<th>Status</th>
				<td>@Model.Payment.PaymentStatus</td>
				<th>Amount</th>
				<td>@Model.Payment.Amount.ToString("C")</td>
			</tr>
			<tr>
				<th>Date</th>
				<td colspan="3">@Model.Payment.PaymentDate</td>
			</tr>
		</table>
	</div>
}

<!-- TICKETS -->
<div class="section">
	<div class="title">Passengers</div>

	@foreach (var ticket in Model.Tickets)
	{
		<div class="ticket">
			<table>
				<tr>
					<th>Ticket No</th>
					<td>@ticket.TicketNumber</td>
					<th>Passenger</th>
					<td>@ticket.FirstName @ticket.LastName</td>
				</tr>
				<tr>
					<th>Passport</th>
					<td>@ticket.PassportNumber</td>
					<th>Seat</th>
					<td>
						@if (ticket.FlightSeat?.Seat != null)
						{
							@($"{ticket.FlightSeat.Seat.Row}{ticket.FlightSeat.Seat.Number} - {ticket.FlightSeat.Seat.Class}")
						}
						else
						{
							<span>Not Assigned</span>
						}
					</td>
				</tr>
				<tr>
					<th>Add-ons</th>
					<td colspan="3">
						@if (ticket.TicketAddOns != null && ticket.TicketAddOns.Any())
						{
							foreach (var addOn in ticket.TicketAddOns)
							{
								<span>@addOn.AddOn.Name </span>
							}
						}
						else
						{
							<span>None</span>
						}
					</td>
				</tr>
				<tr>
					<th>Ticket Price</th>
					<td colspan="3">@ticket.TicketPrice.ToString("C")</td>
				</tr>
			</table>
		</div>
	}
</div>

<!-- FOOTER -->
<div class="center" style="margin-top:40px;">
	<strong>Present this document at the airport check-in counter.</strong>
</div>

