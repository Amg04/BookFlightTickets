@model FlightViewModel

<div class="container py-4">
    <div class="card shadow-lg border-0">
        <!-- Header -->
        <div class="card-header bg-primary text-white py-4">
            <div class="d-flex justify-content-between align-items-center">
                <h1 class="h3 mb-0">
                    <i class="fas fa-plane me-2"></i>Flight Details
                </h1>
                <span class="badge bg-light text-primary fs-6 px-3 py-2">
                    Flight #@Model.Id
                </span>
            </div>
        </div>

        <!-- Flight Info -->
        <div class="card-body p-0">
            <!-- Route Overview -->
            <div class="bg-light py-4 px-3 border-bottom">
                <div class="row align-items-center">
                    <div class="col-md-4 text-center">
                        <div class="mb-2">
                            <span class="badge bg-primary px-3 py-2">
                                <i class="fas fa-plane-departure me-1"></i> Departure
                            </span>
                        </div>
                        <h4 class="text-primary fw-bold">@Model.DepartureAirport?.Code</h4>
                        <p class="mb-1 text-muted">@Model.DepartureAirport?.Name</p>
                        <p class="fw-bold text-dark">
                            <i class="far fa-calendar-alt me-1"></i>
                            @Model.DepartureTime.ToString("ddd, dd MMM yyyy")
                        </p>
                        <p class="fw-bold text-dark">
                            <i class="far fa-clock me-1"></i>
                            @Model.DepartureTime.ToString("HH:mm") Local Time
                        </p>
                    </div>

                    <div class="col-md-4 text-center">
                        <div class="position-relative">
                            <div class="flight-path">
                                <i class="fas fa-plane text-primary" style="font-size: 2rem;"></i>
                                <div class="flight-line"></div>
                            </div>
                            <p class="mt-3 text-muted">
                                <i class="fas fa-clock me-1"></i>
                                Duration: @((Model.ArrivalTime - Model.DepartureTime).Hours)h
                                @((Model.ArrivalTime - Model.DepartureTime).Minutes)m
                            </p>
                        </div>
                    </div>

                    <div class="col-md-4 text-center">
                        <div class="mb-2">
                            <span class="badge bg-success px-3 py-2">
                                <i class="fas fa-plane-arrival me-1"></i> Arrival
                            </span>
                        </div>
                        <h4 class="text-success fw-bold">@Model.ArrivalAirport?.Code</h4>
                        <p class="mb-1 text-muted">@Model.ArrivalAirport?.Name</p>
                        <p class="fw-bold text-dark">
                            <i class="far fa-calendar-alt me-1"></i>
                            @Model.ArrivalTime.ToString("ddd, dd MMM yyyy")
                        </p>
                        <p class="fw-bold text-dark">
                            <i class="far fa-clock me-1"></i>
                            @Model.ArrivalTime.ToString("HH:mm") Local Time
                        </p>
                    </div>
                </div>
            </div>

            <!-- Details Table -->
            <div class="p-4">
                <div class="row">
                    <!-- Flight Information -->
                    <div class="col-lg-6">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0">
                                    <i class="fas fa-info-circle me-2"></i>Flight Information
                                </h5>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless">
                                    <tbody>
                                        <tr>
                                            <th class="text-info w-50">
                                                <i class="fas fa-plane me-2"></i>Airline
                                            </th>
                                            <td class="fw-bold">@Model.Airline?.Name</td>
                                        </tr>
                                        <tr>
                                            <th class="text-info">
                                                <i class="fas fa-plane me-2"></i>Aircraft
                                            </th>
                                            <td class="fw-bold">@Model.Airplane?.Model</td>
                                        </tr>
                                        <tr>
                                            <th class="text-info">
                                                <i class="fas fa-tag me-2"></i>Flight Status
                                            </th>
                                            <td>
                                                @{
                                                    var statusClass = "badge bg-";
                                                    switch (Model.Status)
                                                    {
                                                        case FlightStatus.Scheduled:
                                                            statusClass += "info";
                                                            break;
                                                        case FlightStatus.Boarding:
                                                            statusClass += "warning";
                                                            break;
                                                        case FlightStatus.Departed:
                                                            statusClass += "primary";
                                                            break;
                                                        case FlightStatus.InAir:
                                                            statusClass += "info";
                                                            break;
                                                        case FlightStatus.Landed:
                                                            statusClass += "success";
                                                            break;
                                                        case FlightStatus.Arrived:
                                                            statusClass += "success";
                                                            break;
                                                        case FlightStatus.Delayed:
                                                            statusClass += "warning text-dark";
                                                            break;
                                                        case FlightStatus.Cancelled:
                                                            statusClass += "danger";
                                                            break;
                                                        case FlightStatus.Diverted:
                                                            statusClass += "danger"; 
                                                            break;
                                                        default:
                                                            statusClass += "secondary";
                                                            break;
                                                    }
                                                }
                                                <span class="@statusClass px-3 py-1">@Model.Status</span>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-info">
                                                <i class="fas fa-barcode me-2"></i>Flight ID
                                            </th>
                                            <td class="fw-bold">@Model.Id</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Pricing & Availability -->
                    <div class="col-lg-6">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-success text-white">
                                <h5 class="mb-0">
                                    <i class="fas fa-dollar-sign me-2"></i>Pricing & Availability
                                </h5>
                            </div>
                            <div class="card-body">
                                <table class="table table-borderless">
                                    <tbody>
                                        <tr>
                                            <th class="text-success w-50">
                                                <i class="fas fa-money-bill-wave me-2"></i>Base Price
                                            </th>
                                            <td>
                                                <span class="fw-bold fs-5 text-success">
                                                    @Model.BasePrice.ToString("C")
                                                </span>
                                                <small class="text-muted d-block">per seat</small>
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-success">
                                                <i class="fas fa-chair me-2"></i>Available Seats
                                            </th>
                                            <td>
                                                @{
                                                    var seatsClass = "badge fs-6 px-3 py-2 ";
                                                    var availableSeats = Model.AvailableSeatsCount;

                                                    if (availableSeats > 5)
                                                    {
                                                        seatsClass += "bg-success";
                                                    }
                                                    else if (availableSeats > 0)
                                                    {
                                                        seatsClass += "bg-warning text-dark";
                                                    }
                                                    else
                                                    {
                                                        seatsClass += "bg-danger";
                                                    }
                                                }
                                                <span class="@seatsClass">
                                                    <i class="fas fa-users me-1"></i>
                                                    @availableSeats seats available
                                                </span>
                                                @if (availableSeats > 0 && availableSeats <= 5)
                                                {
                                                    <small class="text-danger d-block mt-1">
                                                        <i class="fas fa-exclamation-triangle me-1"></i>
                                                        Few seats left - Book now!
                                                    </small>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-success">
                                                <i class="fas fa-calendar-alt me-2"></i>Flight Date
                                            </th>
                                            <td class="fw-bold">
                                                @Model.DepartureTime.ToString("dddd, MMMM dd, yyyy")
                                            </td>
                                        </tr>
                                        <tr>
                                            <th class="text-success">
                                                <i class="fas fa-clock me-2"></i>Duration
                                            </th>
                                            <td class="fw-bold">
                                                @{
                                                    var duration = Model.ArrivalTime - Model.DepartureTime;
                                                }
                                                @duration.Hours h @duration.Minutes m
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card-footer bg-light py-3">
            <div class="d-flex justify-content-between">
                <button class="btn btn-outline-secondary px-4" onclick="history.back()">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </button>

                @if (availableSeats > 0)
                {
                    <a href="@Url.Action("Book", "Book", new { area = "Customer", flightId = Model.Id, ticketCount = 1 })"
                       class="btn btn-success px-4">
                        <i class="fas fa-ticket-alt me-2"></i>Book This Flight
                    </a>
                }
                else
                {
                    <button class="btn btn-danger px-4" disabled>
                        <i class="fas fa-times-circle me-2"></i>Sold Out
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gradient-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .flight-path {
        position: relative;
        padding: 20px 0;
    }

    .flight-line {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, #007bff, #28a745);
        z-index: -1;
    }

    .card {
        border-radius: 15px;
        overflow: hidden;
    }

    .card-header {
        border-radius: 0 !important;
    }

    .table-borderless th {
        font-weight: 600;
        padding-left: 0;
    }

    .table-borderless td {
        padding-right: 0;
    }

    .badge {
        border-radius: 20px;
        font-weight: 500;
    }

    .btn {
        border-radius: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    .btn-success {
        background: linear-gradient(135deg, #28a745, #20c997);
        border: none;
    }

    .btn-outline-secondary:hover {
        background-color: #6c757d;
        color: white;
    }
</style>