@{
    ViewData["Title"] = "Payment Cancelled";
}
<partial name="_notification" />
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="position-relative">
                <div class="card shadow-lg border-0 mt-4">
                    <div class="card-header bg-gradient bg-danger text-white">
                        <h3 class="m-0">❌ Payment Cancelled</h3>
                    </div>
                    <div class="card-body p-5 bg-dark text-light">
                        <h4 class="text-danger fw-bold mb-4">Payment was not completed</h4>

                        <div class="alert alert-warning border-0 mb-4">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Booking Cancelled:</strong> Your booking has been automatically cancelled and seats are now available again.
                        </div>

                        <div class="row text-start mb-4">
                            <div class="col-md-6">
                                <h6 class="text-warning"><i class="fas fa-undo me-2"></i>What's Next?</h6>
                                <ul class="small text-muted list-unstyled">
                                    <li>✅ Seats released for other passengers</li>
                                    <li>✅ Booking removed from your account</li>
                                    <li>✅ No charges applied</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6 class="text-info"><i class="fas fa-clock me-2"></i>Try Again?</h6>
                                <p class="small text-muted">You can book again anytime. Seats availability may change.</p>
                            </div>
                        </div>

                        <hr class="border-light opacity-25" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center mt-4">
                            <a asp-area="Customer" asp-controller="Book" asp-action="Book" class="btn btn-outline-warning btn-lg px-4">
                                <i class="fas fa-redo me-2"></i>Book Again
                            </a>
                            <a asp-area="Customer" asp-controller="MyBookings" asp-action="Index" class="btn btn-outline-info btn-lg px-4">
                                <i class="fas fa-list me-2"></i>My Bookings
                            </a>
                            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-dark btn-lg px-4">
                                <i class="fas fa-home me-2"></i>Back to Home
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
