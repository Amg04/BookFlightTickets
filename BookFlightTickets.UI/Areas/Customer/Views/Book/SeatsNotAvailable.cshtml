@{
    ViewData["Title"] = "Seats Not Available";
}

<div class="container text-light mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="alert alert-danger" role="alert">
                <h4 class="alert-heading">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Not Enough Seats Available!
                </h4>
                <hr>
                <p class="mb-4">@ViewBag.ErrorMessage</p>
                <div class="mb-4">
                    <a asp-area="Customer" asp-controller="Flight" asp-action="Index"
                       class="btn btn-info btn-lg me-3">
                        <i class="fas fa-search me-2"></i>Search Other Flights
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
