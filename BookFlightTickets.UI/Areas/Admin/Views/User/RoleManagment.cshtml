@model RoleManagmentVM
<div class="card shadow border-0 my-4">
	<div class="card-header bg-secondary bg-black ml-0 py-3 ">
		<div class="row">
			<div class="col-12 text-center">
				<h2 class="text-white py-2">Manage User Role</h2>
			</div>
		</div>
	</div>
	<div class="card-body p-4">
		<form asp-action="RoleManagment" class="row" enctype="multipart/form-data">
			@Html.AntiForgeryToken()
			<div asp-validation-summary="ModelOnly" class="text-danger"></div>
			<input hidden asp-for="ApplicationUser.Id" />
			<div class="row">
				<div class="col-12">
					<div class="border p-3">
						<div class="form-floating py-2 col-12">
							<input asp-for="ApplicationUser.FirstName"  class="form-control border-0 shadow" disabled/>
							<label asp-for="ApplicationUser.FirstName" class="ms-2"></label>
						</div>

						<div class="form-floating py-2 col-12">
							<select asp-for="ApplicationUser.Role" asp-items="@Model.RoleList" class="form-select">
							</select>
						</div>
						
						<div class="row mt-2">
							<div class="col-6 col-md-3">
								<button type="submit" class="btn btn-primary form-control"><i class="fas fa-edit"></i> Update Role</button>
							</div>
							<div class="col-6 col-md-3">
								<a asp-controller="User" asp-action="Index" class="btn btn-secondary border form-control"><i class="bi bi-arrow-left me-1"></i> Back to list</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</form>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}

