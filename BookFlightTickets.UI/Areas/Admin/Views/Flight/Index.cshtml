@model IEnumerable<FlightViewModel>

@{
    ViewData["Title"] = "Flights";
}

<div class="mb-3">
    <a asp-action="Create" class="btn btn-success">
        <i class="fas fa-plus"></i> Create New Flight
    </a>
    <a asp-action="Search" class="btn btn-secondary">
        <i class="fas fa-search"></i> Search Flights
    </a>
</div>
<partial name="_notification" />


@if (Model.Any())
{
    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-secondary bg-black ml-0 py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="text-white py-2">All Flights</h2>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th>Airline</th>
                            <th>Airplane</th>
                            <th>Departure Airport</th>
                            <th>Arrival Airport</th>
                            <th>Departure Time</th>
                            <th>Arrival Time</th>
                            <th>Base Price</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var flight in Model)
                        {
                            <tr>
                                <td>@flight.Airline?.Name</td>
                                <td>@flight.Airplane?.Model</td>
                                <td>@flight.DepartureAirport?.Name</td>
                                <td>@flight.ArrivalAirport?.Name</td>
                                <td>@flight.DepartureTime.ToString("g")</td>
                                <td>@flight.ArrivalTime.ToString("g")</td>
                                <td>@flight.BasePrice.ToString("C")</td>
                                <td>@flight.Status</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@flight.Id" class="btn btn-sm btn-warning"> <i class="fas fa-info-circle"></i> Details</a>
                                    <a asp-action="Edit" asp-route-id="@flight.Id" class="btn btn-sm btn-primary"><i class="fas fa-edit"></i> Edit</a>
                                    @{
                                        var deleteUrl = Url.Action("Delete", "Flight", new { area = SD.Admin, id = flight.Id });
                                    }
                                    <a onclick="Delete('@deleteUrl')" class="btn btn-danger btn-sm"><i class="fas fa-trash"></i> Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center" role="alert">
        <div class="d-flex flex-column align-items-center">
            <i class="fas fa-inbox fa-3x mb-3 text-muted"></i>
            <h4 class="alert-heading">No Flights Found!</h4>
            <p>There are currently no Flights available. Start by adding a new Flight.</p>
            <a asp-action="Create" class="btn btn-success mt-2">
                <i class="fas fa-plus"></i> Add First Flight
            </a>
        </div>
    </div>
}

@section Scripts {
    <script>
        function Delete(url) {
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#d33",
                cancelButtonColor: "#3085d6",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: url,
                        type: 'DELETE',
                        success: function (data) {
                             if (data.success) {
                            toastr.success(data.message, 'Done!', {
                                timeOut: 2000,
                                onHidden: function() {
                                    window.location.reload();
                                }
                            });
                            } else {
                                toastr.error(data.message);
                            }
                        },
                        error: function (xhr) {
                            toastr.error("Something went wrong.");
                        }
                    })
                }
            });
        }
    </script>
}
