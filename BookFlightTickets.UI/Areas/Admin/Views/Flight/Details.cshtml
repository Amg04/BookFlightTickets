@model FlightViewModel

@{
    ViewData["Title"] = "Flight Details";
}

<div class="card shadow border-0 my-4">
    <div class="card-header bg-secondary bg-black ml-0 py-3 ">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Flight Details</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <div class="row">
            <div class="col-12">
                <div class="border p-3">
                    <div class="form-floating py-2 col-12">
                        <input asp-for="Airline.Name" class="form-control border-0 shadow" disabled />
                        <label class="ms-2">Airline</label>
                    </div>

                     <div class="form-floating py-2 col-12">
                        <input asp-for="Airplane.Model" class="form-control border-0 shadow" disabled />
                        <label class="ms-2">Airplane</label>
                    </div>

                    <div class="form-floating py-2 col-12">
                        <input asp-for="DepartureAirport.Name" class="form-control border-0 shadow" disabled />
                        <label class="ms-2">Departure Airport</label>
                    </div>

                     <div class="form-floating py-2 col-12">
                        <input asp-for="ArrivalAirport.Name" class="form-control border-0 shadow" disabled />
                        <label class="ms-2">Arrival Airport</label>
                    </div>

                    <div class="form-floating py-2 col-12">
                        <input asp-for="DepartureTime" class="form-control border-0 shadow" disabled />
                        <label asp-for="DepartureTime" class="ms-2"></label>
                    </div>

                    <div class="form-floating py-2 col-12">
                        <input asp-for="ArrivalTime" class="form-control border-0 shadow" disabled />
                        <label asp-for="ArrivalTime" class="ms-2"></label>
                    </div>

                    <div class="form-floating py-2 col-12">
                        <input asp-for="BasePrice" class="form-control border-0 shadow" disabled />
                        <label asp-for="BasePrice" class="ms-2"></label>
                    </div>

                    <div class="form-floating py-2 col-12">
                        <input asp-for="Status" class="form-control border-0 shadow" disabled />
                        <label asp-for="Status" class="ms-2"></label>
                    </div>

                    <div class="mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="fas fa-edit"></i>Edit</a>
                        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left me-1"></i>Cancel</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
