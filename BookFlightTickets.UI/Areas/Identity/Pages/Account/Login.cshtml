@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}
<partial name="_notification" />

<div class="container m-2">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm ">
                <div class="card-body ">
                    <h1 class="card-title text-center mb-4">@ViewData["Title"]</h1>
                    <form id="account" method="post" novalidate>
                        <h4 class="text-center">Use a local account to log in.</h4>
                        <hr />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-2">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" type="email" />
                            <label asp-for="Input.Email" >Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" type="password" />
                            <label asp-for="Input.Password" >Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" type="checkbox" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Log in</button>

                        <div class="mt-4 border-top pt-4">
                            <div class="d-flex flex-wrap gap-3">
                                <a id="forgot-password" asp-page="./ForgotPassword"
                                   class="btn btn-outline-primary d-flex align-items-center justify-content-center py-2 flex-fill">
                                    <i class="bi bi-key me-2"></i>
                                    Forgot your password?
                                </a>

                                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                                   class="btn btn-outline-success d-flex align-items-center justify-content-center py-2 flex-fill">
                                    <i class="bi bi-person-plus me-2"></i>
                                    Register as a new user
                                </a>

                                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation"
                                   class="btn btn-outline-info  d-flex align-items-center justify-content-center py-2 flex-fill">
                                    <i class="bi bi-envelope me-2"></i>
                                    Resend email confirmation
                                </a>
                            </div>
                        </div>
                    </form>

                    <section class="mt-4">
                        <div class="position-relative my-4">
                            <hr class="my-4" />
                            <div class="position-absolute top-50 start-50 translate-middle bg-white px-3">
                                <span class="text-muted">or</span>
                            </div>
                        </div>
                        @if ((Model.ExternalLogins?.Count ?? 0) == 0)
                        {
                            <div>
                                <p class="small">
                                    There are no external authentication services configured. See this <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank" rel="noopener noreferrer">article about setting up this ASP.NET application to support logging in via external services</a>.
                                </p>
                            </div>
                        }
                        else
                        {
                            <div class="text-center">
                                <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="form-horizontal d-grid gap-2">
                                    @foreach (var provider in Model.ExternalLogins!)
                                    {
                                        @if (provider.Name == "Google")
                                        {
                                            <div class="d-flex justify-content-center mb-2">
                                                <button type="submit" class="btn btn-light border rounded-circle p-1 d-flex align-items-center justify-content-center"
                                                        style="width: 56px; height: 56px;"
                                                        name="provider" value="@provider.Name"
                                                        title="Log in using your Google account">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24">
                                                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                                                    </svg>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-outline-primary w-100" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                                @provider.DisplayName
                                            </button>
                                        }
                                    }
                                </form>
                            </div>
                        }
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
