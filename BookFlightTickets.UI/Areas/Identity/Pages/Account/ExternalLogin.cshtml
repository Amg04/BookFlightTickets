@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Complete Registration";
}

<div class="container mt-2">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">

                    <!-- Header -->
                    <div class="text-center mb-2">
                        <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle p-3 mb-3">
                            @if (Model.ProviderDisplayName.ToLower().Contains("google"))
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24">
                                    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
                                    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
                                    <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
                                    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
                                </svg>
                            }
                            else
                            {
                                <i class="bi bi-person-plus-fill text-primary fs-2"></i>
                            }
                        </div>
                        <h1 class="h3 fw-bold">Complete Your Registration</h1>
                        <p class="text-muted">Link your @Model.ProviderDisplayName account</p>
                    </div>

                    <!-- Success Message -->
                    <div class="alert alert-success mb-2">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        <strong>Success!</strong> You've authenticated with <strong>@Model.ProviderDisplayName</strong>.
                    </div>

                    <!-- Form -->
                    <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-warning" role="alert"></div>

                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label fw-bold mb-2">
                                <i class="bi bi-envelope-at me-1"></i>Email Address
                            </label>
                            <input asp-for="Input.Email" class="form-control form-control-lg py-3"
                                   autocomplete="email"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small mt-1"></span>
                            <div class="form-text mt-2">
                                This will be your primary email for the account.
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold">
                                <i class="bi bi-person-add me-2"></i>
                                Create Account
                            </button>
                        </div>
                    </form>

                    <!-- Footer -->
                    <div class="text-center mt-2 pt-3 border-top">
                        <p class="text-muted small">
                            By registering, you agree to our
                            <a href="#" class="text-decoration-none">Terms of Service</a> and
                            <a href="#" class="text-decoration-none">Privacy Policy</a>
                        </p>
                        <a href="/" class="btn btn-link text-decoration-none">
                            <i class="bi bi-arrow-left me-1"></i>
                            Return to homepage
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}